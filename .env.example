DATABASE_URL=postgresql://user:password@db:5432/smellymelly

# Square (for payments — Web Payments SDK)
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=sandbox
SQUARE_APPLICATION_ID=

# Admin password (change this!)
ADMIN_PASSWORD=change-me

# Shipping (EasyPost — USPS rates + label purchase)
EASYPOST_API_KEY=
SHIP_FROM_STREET=
SHIP_FROM_CITY=
SHIP_FROM_STATE=
SHIP_FROM_ZIP=
SHIP_FROM_PHONE=

# AI Assistant (Claude)
ANTHROPIC_API_KEY=

# Email (Gmail SMTP). Requires 2FA + app password from
# https://myaccount.google.com/apppasswords . Leave blank in dev — email
# sends become no-ops and log to console.
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_FROM_NAME=Smelly Melly
# Inbox that receives contact-form messages. Defaults to GMAIL_USER if unset.
CONTACT_INBOX_EMAIL=
# Public store URL shown in email footers.
PUBLIC_URL=https://smellymelly.net

# Set to true in dev only — lets admin cookies work over plain HTTP.
DISABLE_SECURE_COOKIES=false
