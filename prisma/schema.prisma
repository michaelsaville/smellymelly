// Smelly Melly — E-commerce for handmade bath & body products
// Uses the shared PostgreSQL database with its own schema namespace.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["smellymelly"]
}

// ─── PRODUCTS ─────────────────────────────────────────────────────────────

model SM_Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products SM_Product[]

  @@map("sm_categories")
  @@schema("smellymelly")
}

model SM_Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  scent       String?
  ingredients String?
  categoryId  String
  category    SM_Category @relation(fields: [categoryId], references: [id])
  isActive    Boolean     @default(true)
  isFeatured  Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  variants SM_ProductVariant[]
  images   SM_ProductImage[]

  @@map("sm_products")
  @@schema("smellymelly")
}

model SM_ProductVariant {
  id            String     @id @default(cuid())
  productId     String
  product       SM_Product @relation(fields: [productId], references: [id])
  name          String
  sku           String?    @unique
  priceCents    Int
  costCents     Int?
  weightOz      Float?
  stockQuantity Int        @default(0)
  lowStockAt    Int        @default(5)
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  orderItems SM_OrderItem[]

  @@map("sm_product_variants")
  @@schema("smellymelly")
}

model SM_ProductImage {
  id        String     @id @default(cuid())
  productId String
  product   SM_Product @relation(fields: [productId], references: [id])
  url       String
  altText   String?
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())

  @@map("sm_product_images")
  @@schema("smellymelly")
}

// ─── SCENTS (reusable scent options) ──────────────────────────────────────

model SM_Scent {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sm_scents")
  @@schema("smellymelly")
}

// ─── ORDERS ───────────────────────────────────────────────────────────────

enum SM_OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  READY_FOR_PICKUP
  DELIVERED
  PICKED_UP
  CANCELLED
  REFUNDED
  @@schema("smellymelly")
}

enum SM_FulfillmentType {
  SHIP
  PICKUP
  @@schema("smellymelly")
}

model SM_Order {
  id              String             @id @default(cuid())
  orderNumber     Int                @unique @default(autoincrement())
  status          SM_OrderStatus     @default(PENDING)
  fulfillment     SM_FulfillmentType

  // Customer info (guest checkout — no account)
  customerName    String
  customerEmail   String
  customerPhone   String?

  // Shipping (null for pickup)
  shippingName    String?
  shippingAddress String?
  shippingCity    String?
  shippingState   String?
  shippingZip     String?

  // Money (all in cents)
  subtotalCents   Int
  shippingCents   Int       @default(0)
  taxCents        Int       @default(0)
  totalCents      Int

  // Square payment
  squarePaymentId String?
  squareOrderId   String?

  // Shipping
  trackingNumber  String?
  shippingLabel   String?
  shippedAt       DateTime?

  // Timestamps
  paidAt          DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  items SM_OrderItem[]

  @@map("sm_orders")
  @@schema("smellymelly")
}

model SM_OrderItem {
  id          String            @id @default(cuid())
  orderId     String
  order       SM_Order          @relation(fields: [orderId], references: [id])
  variantId   String
  variant     SM_ProductVariant @relation(fields: [variantId], references: [id])
  productName String
  variantName String
  quantity    Int
  unitCents   Int
  totalCents  Int

  @@map("sm_order_items")
  @@schema("smellymelly")
}

// ─── INVOICES ─────────────────────────────────────────────────────────────

enum SM_InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
  @@schema("smellymelly")
}

model SM_Invoice {
  id            String           @id @default(cuid())
  invoiceNumber Int              @unique @default(autoincrement())
  status        SM_InvoiceStatus @default(DRAFT)
  orderId       String?

  customerName  String
  customerEmail String?

  subtotalCents Int
  taxCents      Int       @default(0)
  totalCents    Int

  notes         String?
  sentAt        DateTime?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items SM_InvoiceItem[]

  @@map("sm_invoices")
  @@schema("smellymelly")
}

model SM_InvoiceItem {
  id          String     @id @default(cuid())
  invoiceId   String
  invoice     SM_Invoice @relation(fields: [invoiceId], references: [id])
  description String
  quantity    Int        @default(1)
  unitCents   Int
  totalCents  Int

  @@map("sm_invoice_items")
  @@schema("smellymelly")
}

// ─── SETTINGS ─────────────────────────────────────────────────────────────

model SM_Settings {
  id            String  @id @default("singleton")
  businessName  String  @default("Smelly Melly")
  businessEmail String?
  businessPhone String?
  address       String?
  city          String?
  state         String?
  zip           String?
  taxRate       Float   @default(0.06)

  @@map("sm_settings")
  @@schema("smellymelly")
}
